#!/bin/sh

# Run markdown linting on staged .md files
STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

if [ -n "$STAGED_MD_FILES" ]; then
  echo "Linting staged Markdown files..."

  # Check if markdownlint is available
  if command -v npx &> /dev/null; then
    echo "$STAGED_MD_FILES" | xargs npx markdownlint --ignore node_modules --ignore docs --ignore reports
    if [ $? -ne 0 ]; then
      echo ""
      echo "Markdown lint errors found. Fix them or run:"
      echo "  npm run lint:fix"
      echo ""
      exit 1
    fi
  else
    echo "Warning: npx not found, skipping markdown lint"
  fi
fi

# Validate JSON files
STAGED_JSON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.json$' || true)

if [ -n "$STAGED_JSON_FILES" ]; then
  echo "Validating staged JSON files..."

  for file in $STAGED_JSON_FILES; do
    if [ -f "$file" ]; then
      python3 -m json.tool "$file" > /dev/null 2>&1
      if [ $? -ne 0 ]; then
        echo "Invalid JSON: $file"
        exit 1
      fi
    fi
  done
fi

echo "Pre-commit checks passed!"
