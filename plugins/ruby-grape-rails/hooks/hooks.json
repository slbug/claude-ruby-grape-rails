{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/iron-law-verifier.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/security-reminder.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/log-progress.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/plan-stop-reminder.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/secret-scan.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.rb)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Edit(*.rake)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Edit(*Gemfile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Edit(*Rakefile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Edit(*config.ru)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Edit(*.rb)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Edit(*.rake)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Edit(*Gemfile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Edit(*Rakefile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Edit(*config.ru)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Edit(*.rb)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Edit(*.rake)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Edit(*Gemfile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Edit(*Rakefile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(*.rb)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Write(*.rake)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Write(*Gemfile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Write(*Rakefile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Write(*config.ru)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Write(*.rb)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Write(*.rake)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Write(*Gemfile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Write(*Rakefile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Write(*config.ru)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "Write(*.rb)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Write(*.rake)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Write(*Gemfile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Write(*Rakefile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "if": "MultiEdit(*.rb)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "MultiEdit(*.rake)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "MultiEdit(*Gemfile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "MultiEdit(*Rakefile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "MultiEdit(*config.ru)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "MultiEdit(*.rb)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "MultiEdit(*.rake)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "MultiEdit(*Gemfile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "MultiEdit(*Rakefile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "MultiEdit(*config.ru)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-ruby.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "if": "MultiEdit(*.rb)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "MultiEdit(*.rake)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "MultiEdit(*Gemfile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "MultiEdit(*Rakefile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/debug-statement-warning.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block-dangerous-ops.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-failure-hints.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/error-critic.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-iron-laws.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/setup-dirs.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-runtime.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-scratchpad.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-resume.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "echo 'Ruby/Rails/Grape plugin loaded — describe the task and I will route the right workflow'"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "Gemfile|Gemfile\\.lock|Rakefile|lefthook\\.yml|justfile|\\.justfile|Justfile|.*\\.gemspec",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-runtime-file-changed.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/precompact-rules.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/postcompact-verify.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-pending-plans.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-failure-log.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
