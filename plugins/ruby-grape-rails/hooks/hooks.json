{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.rb)|Edit(*.rake)|Edit(*Gemfile)|Edit(*Rakefile)|Edit(config/*)|Edit(*.yml)|Edit(*.env*)|Edit(*.json)|Write(*.rb)|Write(*.rake)|Write(*Gemfile)|Write(*Rakefile)|Write(config/*)|Write(*.yml)|Write(*.env*)|Write(*.json)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/security-reminder.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/log-progress.sh",
            "timeout": 15,
            "async": true
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/secret-scan.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.rb)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/rubyish-post-edit.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Edit(*.rake)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/rubyish-post-edit.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Edit(*Gemfile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/rubyish-post-edit.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Edit(*Rakefile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/rubyish-post-edit.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Edit(*config.ru)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/rubyish-post-edit.sh",
            "timeout": 45
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(*.rb)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/rubyish-post-edit.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Write(*.rake)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/rubyish-post-edit.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Write(*Gemfile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/rubyish-post-edit.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Write(*Rakefile)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/rubyish-post-edit.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Write(*config.ru)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/rubyish-post-edit.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Write(*plan.md)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/plan-stop-reminder.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block-dangerous-ops.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(bundle *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* bundle *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(rails *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* rails *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(bin/rails *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* bin/rails *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(./bin/rails *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* ./bin/rails *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(rake *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* rake *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(bin/rake *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* bin/rake *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(./bin/rake *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* ./bin/rake *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(ruby *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* ruby *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(rspec *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* rspec *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(bin/rspec *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* bin/rspec *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(./bin/rspec *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* ./bin/rspec *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(standardrb *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* standardrb *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(bin/standardrb *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* bin/standardrb *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(./bin/standardrb *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* ./bin/standardrb *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(rubocop *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* rubocop *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(bin/rubocop *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* bin/rubocop *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(./bin/rubocop *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* ./bin/rubocop *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(brakeman *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* brakeman *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(bin/brakeman *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* bin/brakeman *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(./bin/brakeman *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(*=* ./bin/brakeman *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ruby-post-tool-use-failure.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-iron-laws.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/setup-dirs.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-runtime-fast.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-runtime-async.sh",
            "timeout": 30,
            "statusMessage": "Refreshing Ruby runtime context...",
            "async": true
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-scratchpad.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-resume.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "echo 'Ruby/Rails/Grape plugin loaded — describe the task and I will route the right workflow'"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "Gemfile|Gemfile\\.lock|Rakefile|lefthook\\.ya?ml|\\.lefthook\\.ya?ml|lefthook-local\\.ya?ml|\\.lefthook-local\\.ya?ml|justfile|\\.justfile|Justfile|.*\\.gemspec",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-runtime-file-changed.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-runtime-file-changed.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/precompact-rules.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/postcompact-verify.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-pending-plans.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-failure-log.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
